# MongoDB (optional locally — memory mode if unset)
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/brownie-bliss

# SMTP — required to email receipts after payment confirmation
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM=your-email@gmail.com
MAIL_FROM_NAME=Brownie Bliss

# Optional: Fast2SMS for OTP
FAST2SMS_API_KEY=
